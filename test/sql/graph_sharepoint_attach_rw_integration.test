# name: test/sql/graph_sharepoint_attach_rw_integration.test
# description: Integration tests for sharepoint_lists StorageExtension (ATTACH + read)
# group: [erpl_web]

require erpl_web

require-env ERPL_MS_TENANT_ID

require-env ERPL_MS_CLIENT_ID

require-env ERPL_MS_CLIENT_SECRET

require-env ERPL_MS_SHAREPOINT_SITE_NAME

# Create credential secret
statement ok
CREATE SECRET ms_sp_attach_test (
    TYPE microsoft_graph,
    PROVIDER client_credentials,
    tenant_id '${ERPL_MS_TENANT_ID}',
    client_id '${ERPL_MS_CLIENT_ID}',
    client_secret '${ERPL_MS_CLIENT_SECRET}'
);

# ============================================================================
# Phase 1a: ATTACH creates a proper catalog (not views)
# ============================================================================

statement ok
ATTACH '${ERPL_MS_SHAREPOINT_SITE_NAME}' AS sptest (TYPE sharepoint_lists, SECRET 'ms_sp_attach_test');

# ATTACH must enumerate at least one list from the site
query I
SELECT count(*) > 0 FROM information_schema.tables WHERE table_catalog = 'sptest';
----
true

# No system tables like sqlite_master — it is a remote catalog
query I
SELECT count(*) FROM information_schema.tables WHERE table_catalog = 'sptest' AND table_name = 'sqlite_master';
----
0

# Each table must expose at least one column (verifies DESCRIBE works for all lists)
query I
SELECT count(*) > 0 FROM information_schema.columns WHERE table_catalog = 'sptest';
----
true

# Detach cleanly
statement ok
DETACH sptest;
