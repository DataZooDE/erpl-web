# name: test/sql/graph_sharepoint_integration.test
# description: Integration tests for Microsoft Graph SharePoint Lists and Drives
# group: [erpl_web]

require erpl_web

require-env ERPL_MS_TENANT_ID

require-env ERPL_MS_CLIENT_ID

require-env ERPL_MS_CLIENT_SECRET

require-env ERPL_MS_SHAREPOINT_SITE_ID

require-env ERPL_MS_SHAREPOINT_LIST_ID

require-env ERPL_MS_SHAREPOINT_TESTLIST_SITE_ID

require-env ERPL_MS_SHAREPOINT_TESTLIST_SITE_NAME

require-env ERPL_MS_SHAREPOINT_TESTLIST_LIST_ID

require-env ERPL_MS_SHAREPOINT_TESTLIST_LIST_NAME

# Create secret with real credentials
statement ok
CREATE SECRET ms_graph_sp_test (
    TYPE microsoft_graph,
    PROVIDER client_credentials,
    tenant_id '${ERPL_MS_TENANT_ID}',
    client_id '${ERPL_MS_CLIENT_ID}',
    client_secret '${ERPL_MS_CLIENT_SECRET}'
);

# Test: graph_show_sites returns at least one site
query I
SELECT COUNT(*) > 0 FROM graph_show_sites();
----
true

# Test: graph_show_sites returns expected columns
query I
SELECT COUNT(*) FROM (
    SELECT column_name FROM (DESCRIBE SELECT * FROM graph_show_sites())
    WHERE column_name IN ('id', 'name', 'display_name', 'web_url', 'created_at')
);
----
5

# Test: all sites have a non-empty id
query I
SELECT COUNT(*) = 0 FROM graph_show_sites() WHERE id IS NULL OR id = '';
----
true

# Test: graph_show_lists returns data for the test site
query I
SELECT COUNT(*) > 0 FROM graph_show_lists('${ERPL_MS_SHAREPOINT_SITE_ID}');
----
true

# Test: graph_show_lists returns expected columns
query I
SELECT COUNT(*) FROM (
    SELECT column_name FROM (DESCRIBE SELECT * FROM graph_show_lists('${ERPL_MS_SHAREPOINT_SITE_ID}'))
    WHERE column_name IN ('id', 'name', 'display_name', 'description', 'web_url', 'created_at', 'modified_at')
);
----
7

# Test: graph_describe_list returns column schema for the test list (by GUID)
query I
SELECT COUNT(*) > 0 FROM graph_describe_list(
    '${ERPL_MS_SHAREPOINT_SITE_ID}',
    '${ERPL_MS_SHAREPOINT_LIST_ID}'
);
----
true

# Test: graph_describe_list returns expected columns
query I
SELECT COUNT(*) FROM (
    SELECT column_name FROM (
        DESCRIBE SELECT * FROM graph_describe_list(
            '${ERPL_MS_SHAREPOINT_SITE_ID}',
            '${ERPL_MS_SHAREPOINT_LIST_ID}'
        )
    )
    WHERE column_name IN ('name', 'display_name', 'column_type', 'description', 'required')
);
----
5

# Regression: graph_describe_list must accept human-readable site and list names
# (previously failed with "Invalid hostname for this tenancy" because ResolveSiteId
# was not called — fixed in commit 3160cf2)
query I
SELECT COUNT(*) > 0 FROM graph_describe_list(
    '${ERPL_MS_SHAREPOINT_TESTLIST_SITE_NAME}',
    '${ERPL_MS_SHAREPOINT_TESTLIST_LIST_NAME}',
    secret := 'ms_graph_sp_test'
);
----
true

# Test: graph_sharepoint_list_read works without duplicate-column error
# (regression test: SharePoint returns field "ID" which collides case-insensitively with "id")
query I
SELECT COUNT(*) >= 0 FROM graph_sharepoint_list_read(
    '${ERPL_MS_SHAREPOINT_SITE_ID}',
    '${ERPL_MS_SHAREPOINT_LIST_ID}'
);
----
true

# Test: graph_sharepoint_list_read result always has an id column (not a duplicate col1/col2)
query I
SELECT COUNT(*) FROM (
    DESCRIBE SELECT * FROM graph_sharepoint_list_read(
        '${ERPL_MS_SHAREPOINT_SITE_ID}',
        '${ERPL_MS_SHAREPOINT_LIST_ID}'
    )
)
WHERE column_name = 'id';
----
1

# Regression: graph_sharepoint_list_read must accept site and list by name
# (graph_show_lists shows both 'name' and 'display_name'; previously ResolveListId
# only matched displayName so using the 'name' column value failed with
# "No SharePoint list found" when name != displayName, e.g. Events/Ereignisse —
# fixed by matching against both 'name' and 'displayName' fields)
query I
SELECT COUNT(*) >= 0 FROM graph_sharepoint_list_read(
    '${ERPL_MS_SHAREPOINT_TESTLIST_SITE_NAME}',
    '${ERPL_MS_SHAREPOINT_TESTLIST_LIST_NAME}',
    secret := 'ms_graph_sp_test'
);
----
true

# Test: graph_show_drives returns document library drives for the test site
query I
SELECT COUNT(*) > 0 FROM graph_show_drives('${ERPL_MS_SHAREPOINT_SITE_ID}');
----
true

# Test: graph_show_drives returns expected columns
query I
SELECT COUNT(*) FROM (
    SELECT column_name FROM (DESCRIBE SELECT * FROM graph_show_drives('${ERPL_MS_SHAREPOINT_SITE_ID}'))
    WHERE column_name IN ('id', 'name', 'drive_type', 'web_url', 'created_at', 'modified_at')
);
----
6

# Test: all drives have non-empty id and name
query I
SELECT COUNT(*) = 0 FROM graph_show_drives('${ERPL_MS_SHAREPOINT_SITE_ID}')
WHERE id IS NULL OR id = '' OR name IS NULL OR name = '';
----
true

# Cleanup
statement ok
DROP SECRET ms_graph_sp_test;
