# name: test/sql/graph_sharepoint_attach_integration.test
# description: Integration tests for sharepoint_attach function
# group: [erpl_web]

require erpl_web

require-env ERPL_MS_TENANT_ID
require-env ERPL_MS_CLIENT_ID
require-env ERPL_MS_CLIENT_SECRET
require-env ERPL_MS_SHAREPOINT_SITE_NAME

# Create secret with real credentials
statement ok
CREATE SECRET ms_graph_attach_test (
    TYPE microsoft_graph,
    PROVIDER client_credentials,
    tenant_id '${ERPL_MS_TENANT_ID}',
    client_id '${ERPL_MS_CLIENT_ID}',
    client_secret '${ERPL_MS_CLIENT_SECRET}'
);

# ============================================================================
# Test: attach lists (default, auto-inferred)
# ============================================================================

# Attaching a site by name should succeed and return true
query I
SELECT success FROM sharepoint_attach('${ERPL_MS_SHAREPOINT_SITE_NAME}', secret := 'ms_graph_attach_test');
----
true

# After attaching, at least some views should have been created
# (we can't enumerate views created in the current schema directly, but we can check
# that re-attaching with overwrite := true also returns true)
query I
SELECT success FROM sharepoint_attach('${ERPL_MS_SHAREPOINT_SITE_NAME}', secret := 'ms_graph_attach_test', overwrite := true);
----
true

# ============================================================================
# Test: parameter validation (no network needed)
# ============================================================================

# Missing site parameter should fail at bind time
statement error
SELECT * FROM sharepoint_attach(secret := 'ms_graph_attach_test');
----
requires a site name

# Invalid content value should fail at bind time
statement error
SELECT * FROM sharepoint_attach('${ERPL_MS_SHAREPOINT_SITE_NAME}', secret := 'ms_graph_attach_test', content := 'invalid');
----
content must be one of

# Excel/tables mode without drive should fail at bind time
statement error
SELECT * FROM sharepoint_attach('${ERPL_MS_SHAREPOINT_SITE_NAME}', secret := 'ms_graph_attach_test', content := 'excel');
----
requires the 'drive' parameter
