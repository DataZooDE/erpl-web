# name: test/sql/graph_excel_integration.test
# description: Integration tests for Microsoft Graph Excel Workbooks
# group: [erpl_web]

require erpl_web

require-env ERPL_MS_TENANT_ID

require-env ERPL_MS_CLIENT_ID

require-env ERPL_MS_CLIENT_SECRET

require-env ERPL_MS_EXCEL_SITE_ID

require-env ERPL_MS_EXCEL_DRIVE_ID

require-env ERPL_MS_EXCEL_FILE_PATH

# Create secret with real credentials
statement ok
CREATE SECRET ms_graph_excel_test (
    TYPE microsoft_graph,
    PROVIDER client_credentials,
    tenant_id '${ERPL_MS_TENANT_ID}',
    client_id '${ERPL_MS_CLIENT_ID}',
    client_secret '${ERPL_MS_CLIENT_SECRET}'
);

# Test: graph_show_drives returns document library drives for the test site
query I
SELECT COUNT(*) > 0 FROM graph_show_drives('${ERPL_MS_EXCEL_SITE_ID}');
----
true

# Test: graph_show_drives returns expected columns
query I
SELECT COUNT(*) FROM (
    SELECT column_name FROM (DESCRIBE SELECT * FROM graph_show_drives('${ERPL_MS_EXCEL_SITE_ID}'))
    WHERE column_name IN ('id', 'name', 'drive_type', 'web_url', 'created_at', 'modified_at')
);
----
6

# Test: graph_show_files returns the test Excel file
query I
SELECT COUNT(*) > 0 FROM graph_show_files(
    drive := '${ERPL_MS_EXCEL_DRIVE_ID}'
);
----
true

# Test: graph_show_files returns expected columns
query I
SELECT COUNT(*) FROM (
    SELECT column_name FROM (
        DESCRIBE SELECT * FROM graph_show_files(drive := '${ERPL_MS_EXCEL_DRIVE_ID}')
    )
    WHERE column_name IN ('id', 'name', 'web_url', 'size', 'created_at', 'modified_at', 'mime_type', 'is_folder')
);
----
8

# Test: all listed files have a non-empty id and name
query I
SELECT COUNT(*) = 0 FROM graph_show_files(drive := '${ERPL_MS_EXCEL_DRIVE_ID}')
WHERE id IS NULL OR id = '' OR name IS NULL OR name = '';
----
true

# Test: graph_excel_worksheets returns worksheets for the test file
query I
SELECT COUNT(*) > 0 FROM graph_excel_worksheets(
    '${ERPL_MS_EXCEL_FILE_PATH}',
    drive := '${ERPL_MS_EXCEL_DRIVE_ID}'
);
----
true

# Test: graph_excel_worksheets returns expected columns
query I
SELECT COUNT(*) FROM (
    SELECT column_name FROM (
        DESCRIBE SELECT * FROM graph_excel_worksheets(
            '${ERPL_MS_EXCEL_FILE_PATH}',
            drive := '${ERPL_MS_EXCEL_DRIVE_ID}'
        )
    )
    WHERE column_name IN ('name', 'id', 'position', 'visibility')
);
----
4

# Test: all worksheets have a non-empty name
query I
SELECT COUNT(*) = 0 FROM graph_excel_worksheets(
    '${ERPL_MS_EXCEL_FILE_PATH}',
    drive := '${ERPL_MS_EXCEL_DRIVE_ID}'
)
WHERE name IS NULL OR name = '';
----
true

# Test: graph_excel_tables returns named tables for the test file
query I
SELECT COUNT(*) > 0 FROM graph_excel_tables(
    '${ERPL_MS_EXCEL_FILE_PATH}',
    drive := '${ERPL_MS_EXCEL_DRIVE_ID}'
);
----
true

# Test: graph_excel_tables returns expected columns
query I
SELECT COUNT(*) FROM (
    SELECT column_name FROM (
        DESCRIBE SELECT * FROM graph_excel_tables(
            '${ERPL_MS_EXCEL_FILE_PATH}',
            drive := '${ERPL_MS_EXCEL_DRIVE_ID}'
        )
    )
    WHERE column_name IN ('name', 'id', 'show_headers', 'show_totals')
);
----
4

# Test: graph_excel_range reads data from the SalesData sheet
query I
SELECT COUNT(*) > 0 FROM graph_excel_range(
    '${ERPL_MS_EXCEL_FILE_PATH}',
    'SalesData',
    drive := '${ERPL_MS_EXCEL_DRIVE_ID}'
);
----
true

# Test: graph_excel_read reads rows from the SalesTable
query I
SELECT COUNT(*) > 0 FROM graph_excel_read(
    '${ERPL_MS_EXCEL_FILE_PATH}',
    'SalesTable',
    drive := '${ERPL_MS_EXCEL_DRIVE_ID}'
);
----
true

# Cleanup
statement ok
DROP SECRET ms_graph_excel_test;
