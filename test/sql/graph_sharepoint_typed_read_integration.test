# name: test/sql/graph_sharepoint_typed_read_integration.test
# description: Integration tests for typed SharePoint list reading (DOUBLE/TIMESTAMP/VARCHAR columns)
# group: [erpl_web]

require erpl_web

require-env ERPL_MS_TENANT_ID

require-env ERPL_MS_CLIENT_ID

require-env ERPL_MS_CLIENT_SECRET

require-env ERPL_MS_SHAREPOINT_TESTLIST_SITE_ID

require-env ERPL_MS_SHAREPOINT_TESTLIST_LIST_ID

statement ok
CREATE SECRET ms_sptype_test (
    TYPE microsoft_graph,
    PROVIDER client_credentials,
    tenant_id '${ERPL_MS_TENANT_ID}',
    client_id '${ERPL_MS_CLIENT_ID}',
    client_secret '${ERPL_MS_CLIENT_SECRET}'
);

# ============================================================================
# graph_sharepoint_list_read path: verify column types
# ============================================================================

# Number column must come back as DOUBLE
query I
SELECT typeof(Number) FROM graph_sharepoint_list_read(
    '${ERPL_MS_SHAREPOINT_TESTLIST_SITE_ID}',
    '${ERPL_MS_SHAREPOINT_TESTLIST_LIST_ID}',
    secret := 'ms_sptype_test'
) LIMIT 1;
----
DOUBLE

# Date column must come back as TIMESTAMP
query I
SELECT typeof(Date) FROM graph_sharepoint_list_read(
    '${ERPL_MS_SHAREPOINT_TESTLIST_SITE_ID}',
    '${ERPL_MS_SHAREPOINT_TESTLIST_LIST_ID}',
    secret := 'ms_sptype_test'
) LIMIT 1;
----
TIMESTAMP

# Title column must come back as VARCHAR
query I
SELECT typeof(Title) FROM graph_sharepoint_list_read(
    '${ERPL_MS_SHAREPOINT_TESTLIST_SITE_ID}',
    '${ERPL_MS_SHAREPOINT_TESTLIST_LIST_ID}',
    secret := 'ms_sptype_test'
) LIMIT 1;
----
VARCHAR

# Rows with non-null values: Foo=1, Bar=2, Baz=3
query II
SELECT Title, Number FROM graph_sharepoint_list_read(
    '${ERPL_MS_SHAREPOINT_TESTLIST_SITE_ID}',
    '${ERPL_MS_SHAREPOINT_TESTLIST_LIST_ID}',
    secret := 'ms_sptype_test'
) WHERE Title IS NOT NULL ORDER BY Number;
----
Foo	1.0
Bar	2.0
Baz	3.0

# ============================================================================
# ATTACH path: verify column types exposed through catalog
# ============================================================================

statement ok
ATTACH '${ERPL_MS_SHAREPOINT_TESTLIST_SITE_ID}' AS sptypetest (TYPE sharepoint_lists, SECRET 'ms_sptype_test');

# Number column type via information_schema
query I
SELECT data_type FROM information_schema.columns
WHERE table_catalog = 'sptypetest' AND table_name = 'TestList' AND column_name = 'Number';
----
DOUBLE

# Date column type via information_schema
query I
SELECT data_type FROM information_schema.columns
WHERE table_catalog = 'sptypetest' AND table_name = 'TestList' AND column_name = 'Date';
----
TIMESTAMP

# SELECT from catalog returns typed row data
query II
SELECT Title, Number FROM sptypetest.TestList
WHERE Title IS NOT NULL ORDER BY Number;
----
Foo	1.0
Bar	2.0
Baz	3.0

statement ok
DETACH sptypetest;
