    "parameters": {
      "select": {
        "name": "$select",
        "in": "query",
        "description": "Requests that the service returns only the specified properties (see [System Query Option $select](https://help.sap.com/docs/link-disclaimer?site=http%3A%2F%2Fdocs.oasis-open.org%2Fodata%2Fodata%2Fv4.0%2Ferrata03%2Fos%2Fcomplete%2Fpart1-protocol%2Fodata-v4.0-errata03-os-part1-protocol-complete.html%23_System_Query_Option_3) in the OData Version 4.0 Specification).<br><br>For example, to retrieve only the columns Partner_ID and Value, append the syntax ?$select=Partner_ID,Value.",
        "schema": {
          "type": "string"
        }
      },
      "filter": {
        "name": "$filter",
        "in": "query",
        "description": "Request the service to restrict returned results according to the provided criteria: <br> - eq - Equals <br> - ne - Not equal <br> - gt - Greater Than <br> - ge - Greater Than or Equal To <br> - lt - Less Than <br> - le - Less Than or Equal To <br> - and - And <br> - or - Or <br> - not - Not <br> - () - Grouping <br><br>For example, to retrieve only records where Partner_ID=100000005, append the syntax ?$filter=Partner_ID eq 100000005.",
